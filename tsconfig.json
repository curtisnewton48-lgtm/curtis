{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM"]
  },
  "include": ["agents/**/*.ts", "clients/**/*.ts", "config/**/*.json", "schemas/**/*.ts", "tests/**/*.ts", "orchestrator.ts", "types.ts"]
}
